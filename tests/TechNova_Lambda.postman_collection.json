{
  "info": {
    "name": "TechNova Support Bot — Lambda",
    "description": "Integration tests for the TechNova Support Bot deployed on AWS Lambda.\nMirrors all 11 tests in tests/test_lambda.sh.\n\nSet the collection variable `baseUrl` to your Lambda function URL or API Gateway URL before running.",
    "_postman_id": "technova-lambda-v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://<your-lambda-url>",
      "description": "Lambda Function URL or API Gateway base URL (no trailing slash)"
    },
    {
      "key": "apiKey",
      "value": "dev-key-change-me",
      "description": "NEAM_API_KEY set in Lambda environment"
    },
    {
      "key": "sessionId",
      "value": "postman-session-1",
      "description": "Reusable session key for multi-turn tests"
    }
  ],
  "item": [
    {
      "name": "1 — GET /health (no auth)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('status = healthy', () => pm.expect(b.status).to.eql('healthy'));",
              "pm.test('service field present', () => pm.expect(b).to.have.property('service'));",
              "pm.test('knowledge_chunks > 0', () => pm.expect(b.knowledge_chunks).to.be.above(0));",
              "pm.test('llm_backend present', () => pm.expect(b).to.have.property('llm_backend'));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "2a — Auth rejection (no header)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Rejected without auth (401)', () => pm.response.to.have.status(401));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/v1/claw", "host": ["{{baseUrl}}"], "path": ["api","v1","claw"] }
      }
    },
    {
      "name": "2b — Auth rejection (wrong key)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Rejected with wrong key (401)', () => pm.response.to.have.status(401));",
              "const b = pm.response.json();",
              "pm.test('Error message present', () => pm.expect(JSON.stringify(b)).to.match(/invalid|unauthorized/i));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer WRONG_KEY" }],
        "url": { "raw": "{{baseUrl}}/api/v1/claw", "host": ["{{baseUrl}}"], "path": ["api","v1","claw"] }
      }
    },
    {
      "name": "3 — GET /api/v1/claw (list agents)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('support_bot listed', () => pm.expect(b.agents).to.include('support_bot'));",
              "pm.test('active_sessions present', () => pm.expect(b).to.have.property('active_sessions'));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{apiKey}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/claw", "host": ["{{baseUrl}}"], "path": ["api","v1","claw"] }
      }
    },
    {
      "name": "4 — POST message — greeting",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('response field present', () => pm.expect(b).to.have.property('response'));",
              "pm.test('turn counter present', () => pm.expect(b).to.have.property('turn'));",
              "pm.test('turn = 1 (first message)', () => pm.expect(b.turn).to.eql(1));",
              "console.log('Nova:', b.response);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{apiKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"message\": \"Hello! What can you help me with?\"}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/claw/support_bot/sessions/postman-greeting/message",
          "host": ["{{baseUrl}}"],
          "path": ["api","v1","claw","support_bot","sessions","postman-greeting","message"]
        }
      }
    },
    {
      "name": "5 — POST message — order lookup by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('response field present', () => pm.expect(b).to.have.property('response'));",
              "pm.test('ORD-10001 details in response', () => {",
              "  const r = b.response.toLowerCase();",
              "  pm.expect(r).to.match(/ord-10001|delivered|earbuds|alice/i);",
              "});",
              "console.log('Nova:', b.response);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{apiKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"message\": \"Can you look up order ORD-10001 for me?\"}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/claw/support_bot/sessions/postman-order-id/message",
          "host": ["{{baseUrl}}"],
          "path": ["api","v1","claw","support_bot","sessions","postman-order-id","message"]
        }
      }
    },
    {
      "name": "6 — POST message — order lookup by email",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('response field present', () => pm.expect(b).to.have.property('response'));",
              "pm.test('Alice orders in response', () => {",
              "  pm.expect(b.response).to.match(/alice@example\\.com|ORD-10001|ORD-10003|order/i);",
              "});",
              "console.log('Nova:', b.response);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{apiKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"message\": \"I want to check my orders. My email is alice@example.com\"}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/claw/support_bot/sessions/postman-email/message",
          "host": ["{{baseUrl}}"],
          "path": ["api","v1","claw","support_bot","sessions","postman-email","message"]
        }
      }
    },
    {
      "name": "7 — POST message — product stock check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('response field present', () => pm.expect(b).to.have.property('response'));",
              "pm.test('Earbuds info in response', () => {",
              "  pm.expect(b.response).to.match(/earbuds|79|pro wireless|stock|available/i);",
              "});",
              "console.log('Nova:', b.response);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{apiKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"message\": \"Do you have any wireless earbuds in stock?\"}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/claw/support_bot/sessions/postman-product/message",
          "host": ["{{baseUrl}}"],
          "path": ["api","v1","claw","support_bot","sessions","postman-product","message"]
        }
      }
    },
    {
      "name": "8 — POST message — return policy (RAG)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('response field present', () => pm.expect(b).to.have.property('response'));",
              "pm.test('Return policy info in response', () => {",
              "  pm.expect(b.response).to.match(/return|30.?day|refund|polic/i);",
              "});",
              "console.log('Nova:', b.response);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{apiKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"message\": \"What is your return policy?\"}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/claw/support_bot/sessions/postman-policy/message",
          "host": ["{{baseUrl}}"],
          "path": ["api","v1","claw","support_bot","sessions","postman-policy","message"]
        }
      }
    },
    {
      "name": "9a — Multi-turn (turn 1 — open issue)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('turn = 1', () => pm.expect(b.turn).to.eql(1));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{apiKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"message\": \"Hi, I need help with my order\"}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/claw/support_bot/sessions/postman-multi/message",
          "host": ["{{baseUrl}}"],
          "path": ["api","v1","claw","support_bot","sessions","postman-multi","message"]
        }
      }
    },
    {
      "name": "9b — Multi-turn (turn 2 — provide order ID)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('Session history maintained (turn >= 2)', () => pm.expect(b.turn).to.be.at.least(2));",
              "pm.test('ORD-10002 resolved in second turn', () => {",
              "  pm.expect(b.response).to.match(/ORD-10002|shipped|SmartWatch|Bob/i);",
              "});",
              "console.log('Nova:', b.response);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{apiKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"message\": \"The order ID is ORD-10002\"}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/claw/support_bot/sessions/postman-multi/message",
          "host": ["{{baseUrl}}"],
          "path": ["api","v1","claw","support_bot","sessions","postman-multi","message"]
        }
      }
    },
    {
      "name": "10a — Session reset",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('Reset confirmed', () => pm.expect(JSON.stringify(b)).to.match(/reset/i));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{apiKey}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/v1/claw/support_bot/sessions/postman-reset/reset",
          "host": ["{{baseUrl}}"],
          "path": ["api","v1","claw","support_bot","sessions","postman-reset","reset"]
        }
      }
    },
    {
      "name": "10b — First message after reset starts at turn 1",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",

    },
    {
      "name": "11 — GET /api/v1/metrics",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('active_sessions present', () => pm.expect(b).to.have.property('active_sessions'));",
              "pm.test('knowledge_chunks present', () => pm.expect(b).to.have.property('knowledge_chunks'));",
              "pm.test('llm_backend present', () => pm.expect(b).to.have.property('llm_backend'));",
              "console.log('Metrics:', JSON.stringify(b));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{apiKey}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/metrics", "host": ["{{baseUrl}}"], "path": ["api","v1","metrics"] }
      }
    }
  ]
}

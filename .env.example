# ============================================================
# TechNova Support Bot — Environment Variables
# Copy this file to .env and fill in values
# ============================================================

# Neam API key for the HTTP channel (change in production!)
NEAM_API_KEY=dev-key-change-me

# Ollama base URL (use default if running locally)
OLLAMA_BASE_URL=http://localhost:11434

# Log level: debug, info, warn, error
NEAM_LOG_LEVEL=info

# Optional: Admin key for /api/v1/admin endpoints
# NEAM_ADMIN_KEY=your-admin-key
